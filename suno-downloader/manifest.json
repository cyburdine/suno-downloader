{
  "manifest_version": 3,
  "name": "Suno MP3 Downloader",
  "version": "1.0.0",
  "description": "Bulk download all MP3s from Suno.com with custom naming templates.",
  "permissions": [
    "downloads",
    "scripting",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://suno.com/*",
    "https://*.suno.ai/*",
    "https://*.suno.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Suno MP3 Downloader"
  },
  "content_scripts": [
    {
      "matches": [
        "https://suno.com/*"
      ],
      "js": [
        "content/injector.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://suno.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}